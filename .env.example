# Configurações básicas do Django
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True

# Banco de dados
# Localmente o projeto usa SQLite se DATABASE_URL não for informado.
# No Render, esta variável pode ser preenchida automaticamente pelo PostgreSQL.
DATABASE_URL=

# Hosts permitidos
# Exemplo Render:
# ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
